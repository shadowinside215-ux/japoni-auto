rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: cars
    // Document ID: auto-generated
    // Fields: name, year, price, mileage, fuelType, transmission, engine, power, images (list), description, features (list), createdAt
    //
    // Collection: settings
    // Document ID: global
    // Fields: logoUrl, updatedAt
    //
    // Collection: users
    // Document ID: uid
    // Fields: uid, email, role
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dragonballsam86@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidCar(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is string && data.price.size() > 0 &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 10;
    }

    function isValidSettings(data) {
      return data.logoUrl is string && (data.logoUrl.matches("^https://.*") || data.logoUrl == "");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /cars/{carId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidCar(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
